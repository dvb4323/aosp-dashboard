<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/background_dark"
    android:padding="16dp">

    <TextView
        android:id="@+id/appTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CAN Dashboard"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/connectionStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Connected"
        android:textColor="@color/led_on_color"
        android:textSize="13sp"
        app:layout_constraintTop_toTopOf="@id/appTitle"
        app:layout_constraintBottom_toBottomOf="@id/appTitle"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/tabRow"
        android:layout_width="240dp"
        android:layout_height="36dp"
        android:layout_marginTop="10dp"
        android:orientation="horizontal"
        android:background="@drawable/status_card_bg"
        android:padding="3dp"
        app:layout_constraintTop_toBottomOf="@id/appTitle"
        app:layout_constraintStart_toStartOf="parent">

        <Button
            android:id="@+id/dashboardTabButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="2dp"
            android:textSize="11sp"
            android:text="Dashboard"
            android:background="@drawable/button_blink"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/diagnosticsTabButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:textSize="11sp"
            android:text="Diagnostics"
            android:background="@drawable/status_card_bg"
            android:textColor="@color/text_primary" />
    </LinearLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/dashboardContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/tabRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/leftColumn"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:orientation="vertical"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/rightColumn">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/status_card_bg"
                android:padding="16dp">

                <com.example.aospfinal.SpeedometerView
                    android:id="@+id/speedometerView"
                    android:layout_width="150dp"
                    android:layout_height="150dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <TextView
                    android:id="@+id/speedValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/text_primary"
                    android:textSize="30sp"
                    android:textStyle="bold"
                    app:layout_constraintTop_toTopOf="@id/speedometerView"
                    app:layout_constraintBottom_toBottomOf="@id/speedometerView"
                    app:layout_constraintStart_toStartOf="@id/speedometerView"
                    app:layout_constraintEnd_toEndOf="@id/speedometerView"
                    app:layout_constraintVertical_bias="0.4" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="km/h"
                    android:textColor="@color/text_primary"
                    android:alpha="0.6"
                    android:textSize="12sp"
                    app:layout_constraintTop_toBottomOf="@id/speedValue"
                    app:layout_constraintStart_toStartOf="@id/speedValue"
                    app:layout_constraintEnd_toEndOf="@id/speedValue" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/text_primary"
                    android:alpha="0.4"
                    android:textSize="10sp"
                    app:layout_constraintBottom_toBottomOf="@id/speedometerView"
                    app:layout_constraintStart_toStartOf="@id/speedometerView" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="220"
                    android:textColor="@color/text_primary"
                    android:alpha="0.4"
                    android:textSize="10sp"
                    app:layout_constraintBottom_toBottomOf="@id/speedometerView"
                    app:layout_constraintEnd_toEndOf="@id/speedometerView" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/status_card_bg"
                android:padding="16dp"
                android:layout_marginEnd="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Temperature"
                    android:textColor="@color/text_primary"
                    android:alpha="0.7"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tempValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="10dp"
                    android:text="--°C"
                    android:textColor="@color/text_primary"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <ProgressBar
                    android:id="@+id/tempProgressBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:max="100"
                    android:progress="0"
                    android:progressTint="@color/led_on_color" />

                <TextView
                    android:id="@+id/thresholdLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Alert above --°C"
                    android:textColor="@color/text_primary"
                    android:alpha="0.5"
                    android:textSize="10sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="12dp"
                android:orientation="horizontal">

                <TextView android:id="@+id/ledStatusValue" android:text="LED off" android:textColor="@color/text_primary" android:textSize="12sp" android:textStyle="bold" android:background="@drawable/status_card_bg" android:padding="10dp" android:paddingStart="14dp" android:gravity="center_vertical" android:drawableStart="@drawable/ic_bulb" android:drawableTint="@color/icon_muted_color" android:drawablePadding="6dp" android:layout_width="0dp" android:layout_weight="1" android:layout_marginEnd="6dp" android:layout_height="wrap_content" />
                <TextView android:id="@+id/modeValue" android:text="Normal" android:textColor="@color/text_primary" android:textSize="12sp" android:textStyle="bold" android:background="@drawable/status_card_bg" android:padding="10dp" android:paddingStart="14dp" android:gravity="center_vertical" android:drawableStart="@drawable/ic_adjustments" android:drawableTint="@color/icon_muted_color" android:drawablePadding="6dp" android:layout_width="0dp" android:layout_weight="1" android:layout_marginEnd="6dp" android:layout_height="wrap_content" />
                <TextView android:id="@+id/buttonValue" android:text="AC off" android:textColor="@color/text_primary" android:textSize="12sp" android:textStyle="bold" android:background="@drawable/status_card_bg" android:padding="10dp" android:paddingStart="14dp" android:gravity="center_vertical" android:drawableStart="@drawable/ic_ac" android:drawableTint="@color/icon_muted_color" android:drawablePadding="6dp" android:layout_width="0dp" android:layout_weight="1" android:layout_marginEnd="6dp" android:layout_height="wrap_content" />
                <TextView android:id="@+id/errorValue" android:text="OK" android:textColor="@color/text_primary" android:textSize="12sp" android:textStyle="bold" android:background="@drawable/status_card_bg" android:padding="10dp" android:paddingStart="14dp" android:gravity="center_vertical" android:drawableStart="@drawable/ic_warning_triangle" android:drawableTint="@color/icon_muted_color" android:drawablePadding="6dp" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="12dp"
                android:orientation="horizontal">

                <Button android:id="@+id/ledOnButton" android:layout_width="0dp" android:layout_height="64dp" android:layout_weight="1" android:layout_marginEnd="8dp" android:background="@drawable/action_button_bg" android:textColor="@color/icon_muted_color" android:textSize="11sp" android:text="LED ON" android:drawableTop="@drawable/ic_bulb" android:drawableTint="@color/icon_muted_color" android:paddingTop="6dp" android:drawablePadding="4dp" />
                <Button android:id="@+id/ledOffButton" android:layout_width="0dp" android:layout_height="64dp" android:layout_weight="1" android:layout_marginEnd="8dp" android:background="@drawable/action_button_bg" android:textColor="@color/icon_muted_color" android:textSize="11sp" android:text="LED OFF" android:drawableTop="@drawable/ic_power" android:drawableTint="@color/icon_muted_color" android:paddingTop="6dp" android:drawablePadding="4dp" />
                <Button android:id="@+id/blinkButton" android:layout_width="0dp" android:layout_height="64dp" android:layout_weight="1" android:background="@drawable/action_button_bg" android:textColor="@color/icon_muted_color" android:textSize="11sp" android:text="HAZARD" android:drawableTop="@drawable/ic_flash" android:drawableTint="@color/icon_muted_color" android:paddingTop="6dp" android:drawablePadding="4dp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/rightColumn"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:background="@drawable/status_card_bg"
            android:padding="12dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/leftColumn"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintWidth_percent="0.42">

            <ImageView
                android:id="@+id/triangleIcon"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_warning_triangle"
                android:contentDescription="Threshold warning" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/carContainer"
                android:layout_width="200dp"
                android:layout_height="405dp"
                android:layout_marginTop="8dp">

                <ImageView
                    android:id="@+id/carImage"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:src="@drawable/car_body_top"
                    android:scaleType="fitCenter"
                    android:contentDescription="Vehicle status"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <View
                    android:id="@+id/headlightLeft"
                    android:layout_width="28dp"
                    android:layout_height="23dp"
                    android:background="@drawable/headlight_shape"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.331"
                    app:layout_constraintVertical_bias="0.045" />

                <View
                    android:id="@+id/headlightRight"
                    android:layout_width="28dp"
                    android:layout_height="23dp"
                    android:background="@drawable/headlight_shape"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.669"
                    app:layout_constraintVertical_bias="0.045" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/diagnosticsContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tabRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/vinRow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/status_card_bg"
            android:padding="10dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <Button
                android:id="@+id/readVinButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:text="Read VIN" />

            <TextView
                android:id="@+id/vinValue"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:fontFamily="monospace"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:text="Not read yet" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/udsButtonsRow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/vinRow"
            app:layout_constraintStart_toStartOf="@id/vinRow"
            app:layout_constraintEnd_toEndOf="@id/vinRow">

            <Button android:id="@+id/readStatusUdsButton" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:layout_marginEnd="6dp" android:textSize="10sp" android:text="Read Status" />
            <Button android:id="@+id/readSensorUdsButton" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:layout_marginEnd="6dp" android:textSize="10sp" android:text="Read Sensor" />
            <Button android:id="@+id/writeLedUdsButton" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:layout_marginEnd="6dp" android:textSize="10sp" android:text="Write LED" />
            <Button android:id="@+id/writeModeUdsButton" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:textSize="10sp" android:text="Write Mode" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/debugSection"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            android:background="@drawable/status_card_bg"
            android:padding="10dp"
            app:layout_constraintTop_toBottomOf="@id/udsButtonsRow"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Debug frames" android:textColor="@color/text_primary" android:alpha="0.7" android:textSize="12sp" />
                <Button android:id="@+id/readDebugButton" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="11sp" android:text="Clear" android:layout_marginEnd="8dp" />
                <Button android:id="@+id/writeDebugButton" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="11sp" android:text="Clear" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="110dp"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <TextView android:id="@+id/readDebugText" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:layout_marginEnd="8dp" android:background="@color/background_dark" android:padding="8dp" android:fontFamily="monospace" android:textColor="@color/text_primary" android:textSize="11sp" android:text="No frames yet" />
                <TextView android:id="@+id/writeDebugText" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:background="@color/background_dark" android:padding="8dp" android:fontFamily="monospace" android:textColor="@color/text_primary" android:textSize="11sp" android:text="No frames yet" />
            </LinearLayout>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>