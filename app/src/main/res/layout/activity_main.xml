<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/background_dark">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:padding="20dp"
            android:background="@drawable/status_card_bg"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:fontFamily="monospace"
            android:lineSpacingExtra="6dp" />

        <Button
            android:id="@+id/ledOnButton"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/button_led_on"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:text="LED ON" />

        <Button
            android:id="@+id/ledOffButton"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/button_led_off"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:text="LED OFF" />

        <Button
            android:id="@+id/blinkButton"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:background="@drawable/button_blink"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:text="BLINK MODE" />
    </LinearLayout>
</ScrollView>